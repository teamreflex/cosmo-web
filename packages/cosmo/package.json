    "zod": "catalog:"
  },
  "devDependencies": {
    "@apollo/lint": "workspace:*",
    "@apollo/typescript": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
