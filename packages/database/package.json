{
  "name": "@apollo/database",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    "./web/*": "./src/web/*.ts",
    "./indexer/*": "./src/indexer/*.ts",
    "./auth": "./src/auth.ts",
    "./custom": "./src/custom.ts"
  },
  "scripts": {
    "lint": "bun --bun oxlint --type-aware",
    "lint:fix": "bun --bun oxlint --type-aware --fix",
    "typecheck": "tsc --pretty --noEmit",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@apollo/cosmo": "workspace:*",
    "@apollo/util": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@apollo/lint": "workspace:*",
    "@apollo/typescript": "workspace:*",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
