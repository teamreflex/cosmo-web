{
  "name": "schedules",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --bun --watch --env-file=../../.env --env-file=../../.env.local ./src/main.ts",
    "build": "bun build ./src/main.ts --outdir ./dist --target bun",
    "start": "bun run --bun dist/main.js",
    "lint": "bun --bun oxlint --type-aware --type-check",
    "lint:fix": "bun --bun oxlint --type-aware --type-check --fix",
    "typecheck": "tsc --pretty --noEmit",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@apollo/cosmo": "workspace:*",
    "@apollo/database": "workspace:*",
    "@apollo/util": "workspace:*",
    "@effect/cluster": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-bun": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "jose": "catalog:"
  },
  "devDependencies": {
    "@apollo/lint": "workspace:*",
    "@apollo/typescript": "workspace:*",
    "@effect/build-utils": "catalog:",
    "@effect/eslint-plugin": "catalog:",
    "@effect/language-service": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
