{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "env": "bun run --bun --env-file=../../.env --env-file=../../.env.local",
    "dev": "bun run env -- vite",
    "build": "bun run env -- vite build",
    "build:prod": "bun run --bun i18n && bun run --bun typecheck && bun run --bun vite build --mode production",
    "preview": "bun run build && bun run env -- start",
    "start": "bun run --bun --preload ./instrument.ts main.ts",
    "test": "bun test",
    "lint": "bun oxlint --type-aware --type-check",
    "lint:fix": "bun oxlint --type-aware --type-check --fix",
    "typecheck": "tsc --pretty --noEmit",
    "format": "oxfmt .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:upgrade": "drizzle-kit up",
    "db:check": "drizzle-kit check",
    "db:migrate": "bun run env -- drizzle-kit migrate",
    "db:seed": "bun run env -- bun run scripts/seed.ts",
    "auth:generate": "bun run env -- bunx @better-auth/cli generate --output ../../packages/database/src/auth.ts --y",
    "i18n": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/i18n"
  },
  "dependencies": {
    "@apollo/cosmo": "workspace:*",
    "@apollo/database": "workspace:*",
    "@apollo/util": "workspace:*",
    "@apollo/util-server": "workspace:*",
    "@aws-sdk/client-ses": "^3.1075.0",
    "@better-auth/api-key": "1.6.20",
    "@better-auth/drizzle-adapter": "1.6.20",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/bun": "catalog:",
    "@sentry/tanstackstart-react": "^10.61.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-virtual": "^3.14.3",
    "@tanstack/router-core": "1.171.13",
    "better-auth": "1.6.20",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "cnfast": "^0.0.8",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "catalog:",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "fast-average-color-node": "^3.2.0",
    "input-otp": "^1.4.2",
    "jose": "catalog:",
    "motion": "^12.42.0",
    "ofetch": "catalog:",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.80.0",
    "react-intersection-observer": "^10.0.3",
    "react-player": "^3.4.0",
    "recharts": "^2.15.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "srvx": "^0.11.17",
    "tw-animate-css": "^1.4.0",
    "typesense": "catalog:",
    "usehooks-ts": "^3.1.1",
    "zod": "catalog:",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@apollo/lint": "workspace:*",
    "@apollo/typescript": "workspace:*",
    "@inlang/paraglide-js": "2.20.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/eslint-plugin-query": "^5.101.1",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/bun": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/umami": "^2.10.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "catalog:",
    "eslint-plugin-drizzle": "^0.2.3",
    "tailwindcss": "^4.3.1",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.1.0"
  },
  "engines": {
    "bun": ">=1.3.3"
  }
}
