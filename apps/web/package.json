{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "env": "bun run --bun --env-file=../../.env --env-file=../../.env.local",
    "dev": "bun run env -- bun run --bun vite",
    "build": "bun run env -- bun run --bun vite build",
    "build:prod": "bun run --bun i18n && bun run --bun typecheck && bun run --bun vite build --mode production",
    "preview": "bun run build && bun run env -- bun run start",
    "start": "bun run --bun --preload ./instrument.ts main.ts",
    "test": "bun test",
    "lint": "bun --bun oxlint --type-aware --type-check",
    "lint:fix": "bun --bun oxlint --type-aware --type-check --fix",
    "typecheck": "tsc --pretty --noEmit",
    "format": "oxfmt .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:upgrade": "drizzle-kit up",
    "db:migrate": "bun run env -- drizzle-kit migrate",
    "db:seed": "bun run env -- bun run scripts/seed.ts",
    "auth:generate": "bun run env -- bunx @better-auth/cli generate --output ../../packages/database/src/auth.ts --y",
    "i18n": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/i18n"
  },
  "dependencies": {
    "@apollo/cosmo": "workspace:*",
    "@apollo/database": "workspace:*",
    "@apollo/util": "workspace:*",
    "@apollo/util-server": "workspace:*",
    "@aws-sdk/client-ses": "^3.1032.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/tanstackstart-react": "^10.49.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.42",
    "@tanstack/react-virtual": "^3.13.24",
    "better-auth": "1.4.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "catalog:",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "fast-average-color-node": "^3.2.0",
    "input-otp": "^1.4.2",
    "jose": "catalog:",
    "motion": "^12.38.0",
    "ofetch": "catalog:",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "react-intersection-observer": "^10.0.3",
    "react-player": "^3.4.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^2.15.4",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "srvx": "^0.11.15",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typesense": "catalog:",
    "usehooks-ts": "^3.1.1",
    "zod": "catalog:",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@apollo/lint": "workspace:*",
    "@apollo/typescript": "workspace:*",
    "@inlang/paraglide-js": "2.16.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sentry/vite-plugin": "^5.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-plugin-query": "^5.99.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/bun": "catalog:",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/umami": "^2.10.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "catalog:",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-react-refresh": "^0.5.2",
    "tailwindcss": "^4.2.2",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.0.9"
  },
  "engines": {
    "bun": ">=1.3.3"
  }
}
