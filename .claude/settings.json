{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(turbo lint:*)",
      "Bash(turbo typecheck:*)",
      "Bash(turbo format:*)",
      "Bash(turbo test:*)",
      "Bash(turbo i18n:*)",
      "Bash(turbo build:*)",
      "Bash(turbo db:generate:*)",
      "Bash(turbo dev:*)"
    ],
    "deny": ["Bash(npm:*)", "Bash(pnpm:*)"]
  },
  "enabledMcpjsonServers": ["bun", "context7"],
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "agent-browser@agent-browser": true
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "source": "git",
        "url": "https://github.com/vercel-labs/agent-browser.git"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path'); case \"$f\" in *.ts|*.tsx) bunx oxfmt \"$f\" && bunx oxlint --type-aware --fix \"$f\";; esac"
          }
        ]
      }
    ]
  }
}
